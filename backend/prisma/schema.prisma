generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  TEACHER
  STUDENT
}

enum Gender {
  Nam
  Nu
  Khac
}

enum SalaryType {
  PERCENT
  HOURLY
}

enum TuitionStatus {
  PAID
  PENDING
  DEBT
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE_REQUEST
}

enum AttendanceSlot {
  MORNING
  AFTERNOON
  EVENING
  CUSTOM
}

enum AttendanceAuditAction {
  CREATE
  UPDATE
  DELETE
}

enum TransactionStatus {
  SUCCESS
  FAILED
}

enum PaymentAdjustmentSource {
  CASH
  ADJUSTMENT
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      Role
  name      String
  teacherId String?  @unique
  studentId String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isActive  Boolean  @default(true)
  student   Student? @relation(fields: [studentId], references: [id])
  teacher   Teacher? @relation(fields: [teacherId], references: [id])
}

model Teacher {
  id             String     @id @default(uuid())
  name           String
  specialization String?
  workplace      String?
  dob            DateTime?
  gender         Gender?
  cccd           String?
  phone          String
  bankAccount    String?
  bankName       String?
  salaryRate     Float
  notes          String?    @db.Text
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  zaloUserId     String?
  isActive       Boolean    @default(true)
  hourlyRate     Float?
  salaryType     SalaryType @default(PERCENT)
  sortOrder      Int        @default(0)
  classes        Class[]
  user           User?
}

model Student {
  id                 String              @id @default(uuid())
  name               String
  birthYear          Int?
  address            String?
  schoolName         String?
  schoolClass        String?
  cccd               String?
  tuitionStatus      TuitionStatus       @default(PENDING)
  studentCode        String?             @unique
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  parentPhone        String?
  studentPhone       String?
  zaloUserId         String?
  isActive           Boolean             @default(true)
  notes              String?             @db.Text
  sortOrder          Int                 @default(0)
  attendances        Attendance[]
  classes            ClassStudent[]
  paymentAdjustments PaymentAdjustment[]
  transactions       Transaction[]
  user               User?
  zaloMessageLogs    ZaloMessageLog[]
  tuitionBills       TuitionBill[]
}

model Room {
  id       String  @id @default(uuid())
  name     String
  center   String
  capacity Int
  notes    String? @db.Text
  classes  Class[] @relation("ClassRoom1")
  classes2 Class[] @relation("ClassRoom2")
}

model Class {
  id                String         @id @default(uuid())
  name              String
  tuitionPerSession Int
  totalSessions     Int
  classCode         String?        @unique
  teacherShare      Float?
  scheduleDays      String[]
  scheduleTime      String?
  roomId            String?
  teacherId         String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  roomId2           String?
  scheduleTime2     String?
  sortOrder         Int            @default(0)
  attendances       Attendance[]
  room              Room?          @relation("ClassRoom1", fields: [roomId], references: [id])
  room2             Room?          @relation("ClassRoom2", fields: [roomId2], references: [id])
  teacher           Teacher        @relation(fields: [teacherId], references: [id])
  students          ClassStudent[]
}

model ClassStudent {
  classId                String
  studentId              String
  customTuitionPerSession Int?
  discountFrom           DateTime?
  discountTo             DateTime?
  discountReason         String?
  class                  Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  student                Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([classId, studentId])
}


model Attendance {
  id             String            @id @default(uuid())
  date           DateTime
  status         AttendanceStatus
  note           String?           @db.Text
  markedByUserId String?
  markedByName   String?
  markedByRole   String?
  markedAt       DateTime          @default(now())
  classId        String
  studentId      String
  sessionUnits   Float             @default(1)
  slot           AttendanceSlot    @default(MORNING)
  class          Class             @relation(fields: [classId], references: [id])
  student        Student           @relation(fields: [studentId], references: [id])
  audits         AttendanceAudit[]

  @@unique([classId, studentId, date, slot])
}

model AttendanceAudit {
  id              String                @id @default(uuid())
  attendanceId    String?
  action          AttendanceAuditAction
  reason          String?
  classId         String
  studentId       String
  oldStudentId    String?
  date            DateTime
  oldDate         DateTime?
  slot            AttendanceSlot
  oldSlot         AttendanceSlot?
  status          AttendanceStatus
  oldStatus       AttendanceStatus?
  sessionUnits    Float
  oldSessionUnits Float?
  note            String?               @db.Text
  oldNote         String?               @db.Text
  changedByUserId String?
  changedByName   String?
  changedByRole   String?
  changedAt       DateTime              @default(now())
  attendance      Attendance?           @relation(fields: [attendanceId], references: [id], onDelete: SetNull)
}

model Transaction {
  id            String            @id @default(uuid())
  amount        Int
  date          DateTime          @default(now())
  status        TransactionStatus @default(SUCCESS)
  sepayId       Int?              @unique
  gateway       String?
  content       String?
  transferDate  DateTime?
  referenceCode String?
  studentId     String
  classId       String?
  student       Student           @relation(fields: [studentId], references: [id])
}

model PaymentAdjustment {
  id              String                  @id @default(uuid())
  studentId       String
  classId         String?
  source          PaymentAdjustmentSource @default(CASH)
  amount          Int
  note            String?                 @db.Text
  effectiveDate   DateTime                @default(now())
  createdByUserId String?
  createdByName   String?
  createdByRole   String?
  createdAt       DateTime                @default(now())
  student         Student                 @relation(fields: [studentId], references: [id])
}

model ZaloTemplate {
  id           String   @id @default(uuid())
  templateId   String   @unique
  templateName String
  status       String
  previewUrl   String?
  price        Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Campaign {
  id           String           @id @default(uuid())
  name         String
  type         String
  status       String           @default("DRAFT")
  filtersJson  String           @default("{}")
  sentCount    Int              @default(0)
  znsSentCount Int              @default(0)
  readCount    Int              @default(0)
  failedCount  Int              @default(0)
  createdAt    DateTime         @default(now())
  sentAt       DateTime?
  logs         ZaloMessageLog[]
}

model ZaloMessageLog {
  id              String    @id @default(uuid())
  phone           String
  zaloUserId      String?
  templateId      String
  trackingId      String    @unique
  status          String
  errorReason     String?
  sentAt          DateTime  @default(now())
  readAt          DateTime?
  studentId       String?
  campaignId      String?
  classId         String?
  billId          String?
  deliveredAt     DateTime?
  zaloMsgId       String?
  messageType     String?
  customPayload   String?   @db.Text
  coveredClassIds String[]  @default([])
  billingMonth    String?   // "2026-06"
  campaign        Campaign? @relation(fields: [campaignId], references: [id])
  student         Student?  @relation(fields: [studentId], references: [id])
  bill            TuitionBill? @relation(fields: [billId], references: [id])
}

model SystemConfig {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model ZaloMappingAudit {
  id                 String   @id @default(cuid())
  action             String
  zaloUserId         String
  targetType         String
  targetId           String
  targetName         String
  previousTargetId   String?
  previousTargetName String?
  performedBy        String
  performedByName    String
  performedAt        DateTime @default(now())

  @@index([zaloUserId])
  @@index([targetId])
  @@index([performedAt])
}

enum BillStatus {
  UNPAID
  PARTIAL
  PAID
  CANCELLED
}

model TuitionBill {
  id              String       @id @default(cuid())
  studentId       String
  coveredClassIds String[]
  fromDate        DateTime
  toDate          DateTime
  sessionsDetail  String       @db.Text  // JSON: [{classId, className, sessions, pricePerSession, subtotal}]
  amount          Int                    // Tổng tiền phải trả (VND)
  paidAmount      Int          @default(0)
  referenceCode   String       @unique   // "HD-XXXXXX" nhúng vào QR memo
  status          BillStatus   @default(UNPAID)
  dueDate         DateTime?
  notes           String?      @db.Text
  createdByName   String
  sentAt          DateTime?
  billingMonth    String?      // "2026-06"
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  student         Student      @relation(fields: [studentId], references: [id])
  payments        BillPayment[]
  messageLog      ZaloMessageLog[]
}

model BillPayment {
  id            String       @id @default(cuid())
  billId        String
  amount        Int
  paidAt        DateTime     @default(now())
  source        String       // "SEPAY" | "CASH" | "ADJUSTMENT"
  transactionId String?      // → Transaction.id nếu là SePay
  adjustmentId  String?      // → PaymentAdjustment.id nếu là cash
  note          String?
  bill          TuitionBill  @relation(fields: [billId], references: [id])
}
